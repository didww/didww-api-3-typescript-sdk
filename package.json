{
  "name": "@didww/sdk",
  "version": "1.0.0",
  "description": "DIDWW API v3 TypeScript SDK",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "kitsu-core": "^10.1.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "nock": "^14.0.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^2.1.8",
    "yaml": "^2.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
